---
// src/components/QuickApply.astro
---
<section id="apply" class="py-8 md:py-14 bg-slate-900 text-white rounded-3xl md:rounded-[3rem] mx-4 md:mx-6 my-6 md:my-10 overflow-hidden relative">
  <div class="max-w-3xl mx-auto px-6 relative z-10">
    <div class="text-center mb-8">
      <span class="inline-flex items-center px-3 py-1 rounded-full text-xs font-bold uppercase tracking-widest bg-simsek-green/20 text-simsek-green border border-simsek-green/30 mb-3">
        Bewerben
      </span>
      <h2 class="text-2xl md:text-3xl font-bold mb-3 leading-tight">Erst kennenlernen, dann bewerben</h2>
      <div class="h-px bg-linear-to-r from-transparent via-simsek-green/40 to-transparent mb-3"></div>
      <p class="text-slate-400">In 30 Sekunden zum unverbindlichen Erstkontakt — kein Lebenslauf nötig.</p>
    </div>

    <div class="bg-white/5 border border-white/10 p-4 sm:p-6 rounded-2xl backdrop-blur-xl">

      <div id="step-1" class="apply-step space-y-4">
        <h3 class="text-lg font-semibold text-center">Bist du bereits fertige Logopädin?</h3>
        <div class="grid sm:grid-cols-2 gap-3">
          <button
            onclick="nextStep(1, 'Staatlich geprüfte Logopädin')"
            class="py-3 px-6 border border-white/20 rounded-full text-white font-bold cursor-pointer hover:bg-linear-to-r hover:from-simsek-green/25 hover:to-simsek-blue/25 hover:border-simsek-green/60 transition-all duration-200 active:scale-[0.97]"
          >
            Ja, geprüft
          </button>
          <button
            onclick="nextStep(1, 'In Ausbildung')"
            class="py-3 px-6 border border-white/20 rounded-full text-white font-bold cursor-pointer hover:bg-linear-to-r hover:from-simsek-green/25 hover:to-simsek-blue/25 hover:border-simsek-green/60 transition-all duration-200 active:scale-[0.97]"
          >
            In Ausbildung
          </button>
        </div>
      </div>

      <div id="step-2" class="apply-step hidden space-y-4">
        <h3 class="text-lg font-semibold text-center">Was suchst du gerade?</h3>
        <div class="grid sm:grid-cols-3 gap-3">
          <button
            onclick="nextStep(2, 'Schnellstmöglich starten')"
            class="py-3 px-4 border border-white/20 rounded-full text-white font-bold cursor-pointer hover:bg-linear-to-r hover:from-simsek-green/25 hover:to-simsek-blue/25 hover:border-simsek-green/60 transition-all duration-200 active:scale-[0.97]"
          >
            Start bald
          </button>
          <button
            onclick="nextStep(2, 'Teilzeit / Stundenmodell klären')"
            class="py-3 px-4 border border-white/20 rounded-full text-white font-bold cursor-pointer hover:bg-linear-to-r hover:from-simsek-green/25 hover:to-simsek-blue/25 hover:border-simsek-green/60 transition-all duration-200 active:scale-[0.97]"
          >
            Teilzeit klären
          </button>
          <button
            onclick="nextStep(2, 'Unverbindlich kennenlernen')"
            class="py-3 px-4 border border-white/20 rounded-full text-white font-bold cursor-pointer hover:bg-linear-to-r hover:from-simsek-green/25 hover:to-simsek-blue/25 hover:border-simsek-green/60 transition-all duration-200 active:scale-[0.97]"
          >
            Erst sprechen
          </button>
        </div>
      </div>

      <div id="step-3" class="apply-step hidden text-center space-y-4">
        <h3 class="text-2xl font-bold text-transparent bg-clip-text bg-linear-to-r from-simsek-green to-simsek-blue">Fast geschafft!</h3>
        <p class="text-slate-300 text-sm">Wie möchtest du den ersten Kontakt starten?</p>

        <div class="flex flex-col sm:flex-row gap-3 justify-center">

          <a
            id="wa-link"
            href="#"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center justify-center gap-2.5 px-8 py-4 bg-linear-to-r from-simsek-green to-simsek-blue text-white font-bold rounded-full shadow-md shadow-simsek-green/30 hover:shadow-lg hover:shadow-simsek-green/40 hover:scale-[1.03] active:scale-[0.97] transition-all duration-200 no-underline"
          >
            <svg class="w-5 h-5 shrink-0" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L0 24l6.335-1.662c1.72.937 3.672 1.433 5.662 1.434h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            Per WhatsApp
          </a>

          <a
            id="mail-link"
            href="#"
            class="inline-flex items-center justify-center gap-2.5 px-8 py-4 bg-transparent text-white font-bold rounded-full border-2 border-white/30 hover:border-simsek-blue/60 hover:bg-linear-to-r hover:from-simsek-green/20 hover:to-simsek-blue/20 hover:scale-[1.03] active:scale-[0.97] transition-all duration-200 no-underline"
          >
            <svg class="w-5 h-5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path></svg>
            Per E-Mail
          </a>

        </div>
      </div>

      <p class="text-center text-slate-400 text-sm mt-4">
        Kurze Nachricht reicht: Abschluss, Stundenwunsch, möglicher Start.
      </p>
    </div>
  </div>
</section>

<script is:inline>
let data = { step1: '', step2: '' };

function nextStep(step, val) {
  if(step === 1) data.step1 = val;
  if(step === 2) { data.step2 = val; updateLinks(); }

  document.getElementById(`step-${step}`).classList.add('hidden');
  document.getElementById(`step-${step+1}`).classList.remove('hidden');
}

function updateLinks() {
  const phone = "4920334868690";
  const msg = `Hallo Emel! Ich interessiere mich für den Logopädie-Job.\nStatus: ${data.step1}\nWunsch: ${data.step2}\n\nMein Abschluss:\nMein Stundenwunsch:\nMöglicher Start:`;

  const waLink = document.getElementById('wa-link');
  waLink.href = `https://api.whatsapp.com/send?phone=${phone}&text=${encodeURIComponent(msg)}`;

  document.getElementById('mail-link').href = `mailto:info@logopaedie-simsek.de?subject=Unverbindliches%20Kennenlernen%20Logop%C3%A4die-Job&body=${encodeURIComponent(msg)}`;
}
</script>
