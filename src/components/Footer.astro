---
// src/components/Footer.astro
import Logo from './Logo.astro';

const footerLinks = [
  { href: '/#benefits', label: 'Vorteile' },
  { href: '/#faq', label: 'FAQ' },
  { href: '/jobs/logopaedin-sprachtherapeut-duisburg/', label: 'Aktuelle Stellen', highlight: true },
  { href: '/berufshandbuch/', label: 'Berufshandbuch' },
  { href: '/gehaltsrechner/', label: 'Gehaltsrechner' },
  { href: 'https://logopaedie-simsek.de/karriere/', label: 'Zur Praxis ↗', highlight: true, external: true },
];
---
<footer class="bg-slate-950 text-white pt-20 pb-10 relative">
  <!-- Accent stripe (mirrors nav) -->
  <div class="absolute top-0 left-0 right-0 h-0.5 bg-linear-to-r from-simsek-green via-simsek-blue to-simsek-green"></div>

  <div class="max-w-7xl mx-auto px-6">
    <div class="grid md:grid-cols-3 gap-16 mb-16 text-left">
      <div class="space-y-6">
        <Logo class="h-10 w-auto" />
        <p class="text-slate-400 text-sm">Karriere-Portal der Praxis für Logopädie Şimşek.</p>
      </div>
      <div>
        <span class="inline-flex items-center px-3 py-1 rounded-full text-[10px] font-bold uppercase tracking-widest bg-white/5 text-slate-400 border border-white/10 mb-5">Navigation</span>
        <ul class="grid grid-cols-2 gap-x-8 gap-y-3 text-sm list-none p-0 max-w-sm">
          {footerLinks.map((link) => (
            <li>
              <a
                href={link.href}
                target={link.external ? '_blank' : undefined}
                rel={link.external ? 'noopener noreferrer' : undefined}
                class={[
                  'inline-flex items-center font-semibold no-underline transition-colors duration-150',
                  link.highlight
                    ? 'text-simsek-green hover:text-white'
                    : 'text-slate-400 hover:text-white',
                ].join(' ')}
              >
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>
      <div>
        <span class="inline-flex items-center px-3 py-1 rounded-full text-[10px] font-bold uppercase tracking-widest bg-white/5 text-slate-400 border border-white/10 mb-5">Standort</span>
        <p class="text-sm text-slate-400 mb-2">Tonhallenstraße 21, 47051 Duisburg</p>
        <p class="text-xs text-slate-500 mb-6">(3. OG, Aufzug vorhanden)</p>
        <a
          href="mailto:info@logopaedie-simsek.de"
          class="inline-flex items-center gap-2 px-4 py-2.5 bg-linear-to-r from-simsek-green to-simsek-blue text-white text-sm font-bold rounded-full shadow-md shadow-simsek-green/20 hover:shadow-lg hover:shadow-simsek-green/30 hover:scale-[1.02] transition-all duration-200 no-underline"
        >
          <svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
          </svg>
          info@logopaedie-simsek.de
        </a>
      </div>
    </div>
    <div class="pt-8 border-t border-slate-900 flex flex-col sm:flex-row gap-4 justify-between text-[10px] uppercase font-bold text-slate-600">
      <p>© {new Date().getFullYear()} Praxis für Logopädie Şimşek</p>
      <div class="flex gap-4">
        <a href="/impressum" class="no-underline hover:text-slate-400 transition-colors">Impressum</a>
        <a href="/datenschutz" class="no-underline hover:text-slate-400 transition-colors">Datenschutz</a>
      </div>
    </div>
  </div>
</footer>
