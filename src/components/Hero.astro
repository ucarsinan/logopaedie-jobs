---
// src/components/Hero.astro
import { Image } from 'astro:assets';
import sucheImg from '../assets/suche.jpg';
---

<section class="max-w-7xl mx-auto px-4 sm:px-6 pt-10 md:pt-24 pb-12 md:pb-24 relative">
  <div class="absolute inset-0 overflow-hidden pointer-events-none -z-10">
    <div class="absolute -top-24 -right-24 w-96 h-96 bg-simsek-green/10 blur-[120px] rounded-full"></div>
    <div class="absolute top-1/2 -left-24 w-72 h-72 bg-simsek-blue/10 blur-[100px] rounded-full"></div>
  </div>

  <div class="grid lg:grid-cols-2 gap-10 lg:gap-16 items-center">

    <div class="space-y-8">
      <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-white border border-slate-200 shadow-sm animate-fade-in">
         <span class="w-2 h-2 rounded-full bg-simsek-green animate-pulse"></span>
         <span class="text-sm font-medium text-slate-600">Wir suchen Logopädinnen (m/w/d)</span>
      </div>

      <h1 class="text-3xl sm:text-5xl md:text-7xl font-bold text-slate-900 leading-[1.05] tracking-tight uppercase">
        Logopädie Jobs<br/>
        <span class="text-transparent bg-clip-text bg-linear-to-r from-simsek-blue to-simsek-green">Duisburg 2026.</span>
      </h1>

      <p class="text-base sm:text-xl text-slate-600 leading-relaxed max-w-lg">
        Vollzeit oder Teilzeit · <strong>Tonhallenstraße 21</strong>, direkt am Duisburger Hauptbahnhof. Werde Teil eines bilingualen Teams.
      </p>

      <div class="flex flex-col sm:flex-row flex-wrap gap-3 pt-4">
        <a
          href="https://api.whatsapp.com/send?phone=4920334868690&text=Hallo%20Emel!%20Ich%20interessiere%20mich%20f%C3%BCr%20den%20Job."
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center justify-center gap-2.5 px-6 py-3.5 bg-linear-to-r from-simsek-green to-simsek-blue text-white text-sm font-bold rounded-full shadow-md shadow-simsek-green/20 hover:shadow-lg hover:shadow-simsek-green/30 hover:scale-[1.03] active:scale-[0.97] transition-all duration-200 no-underline"
        >
          <svg class="w-5 h-5 shrink-0" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L0 24l6.335-1.662c1.72.937 3.672 1.433 5.662 1.434h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
          Per WhatsApp
        </a>
        <a
          href="mailto:info@logopaedie-simsek.de?subject=Bewerbung"
          class="inline-flex items-center justify-center gap-2.5 px-6 py-3.5 bg-transparent text-slate-700 text-sm font-bold rounded-full border-2 border-slate-200 hover:border-simsek-blue hover:bg-linear-to-r hover:from-simsek-green/10 hover:to-simsek-blue/10 hover:text-slate-900 transition-all duration-200 no-underline"
        >
          <svg class="w-5 h-5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path></svg>
          Per E-Mail
        </a>
      </div>
    </div>

    <div class="relative">
      <div class="relative group">

          <div class="rounded-[3rem] overflow-hidden shadow-2xl border-8 border-white relative bg-slate-50">
          <Image
            src={sucheImg}
            alt="Praxis für Logopädie Şimşek Duisburg – Modernes Therapiezimmer"
            width={900}
            height={700}
            class="w-full h-auto object-contain transform transition duration-700 group-hover:scale-105"
            loading="eager"
            fetchpriority="high"
          />
        </div>

        <div class="absolute -bottom-6 -left-4 md:-left-10 bg-white p-4 md:p-6 rounded-3xl shadow-xl border border-slate-100 animate-bounce-slow z-20">
          <div class="flex items-center gap-4">
            <div class="w-12 h-12 rounded-full bg-simsek-green/10 flex items-center justify-center text-simsek-green font-bold text-sm">
              4T
            </div>
            <div>
              <p class="text-xs text-slate-500 font-medium tracking-widest uppercase">Modell</p>
              <p class="font-bold text-slate-900">4-Tage-Woche</p>
            </div>
          </div>
        </div>

        <div class="absolute -top-6 -right-2 md:-right-6 bg-white p-4 rounded-2xl shadow-lg border border-slate-100 hidden md:block z-20 animate-bounce-slow" style="animation-delay: 1s;">
           <div class="flex items-center gap-2 px-2">
             <span class="text-simsek-green font-bold text-sm">Top Gehalt</span>
             <svg class="w-4 h-4 text-simsek-green" fill="none" stroke="currentColor" viewBox="0 0 24 24">
               <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
             </svg>
           </div>
        </div>

      </div>
    </div>

  </div>
</section>

<style>
  @keyframes fade-in {
    from { opacity: 0; transform: translateY(10px); }
    to { opacity: 1; transform: translateY(0); }
  }
  .animate-fade-in { animation: fade-in 0.8s ease-out forwards; }

  @keyframes bounce-slow {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-12px); }
  }
  .animate-bounce-slow { animation: bounce-slow 5s infinite ease-in-out; }
</style>
