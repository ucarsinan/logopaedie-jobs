---
const faqs = [
  {
    q: "Welche Stelle bietet die Praxis Şimşek an?",
    a: "Wir suchen eine Logopädin bzw. einen Logopäden (m/w/d) in Vollzeit oder Teilzeit. Die Stelle ist an unserem Standort Tonhallenstraße 21, 47051 Duisburg – nur 2 Minuten vom Hauptbahnhof."
  },
  {
    q: "Wie hoch ist das Gehalt als Logopädin bei Praxis Şimşek?",
    a: "Wir zahlen deutlich über dem NRW-Branchendurchschnitt für Logopädinnen – und das merkt man. Die genaue Zahl besprechen wir im persönlichen Gespräch, abhängig von Erfahrung und Stundenzahl."
  },
  {
    q: "Wie läuft die Bewerbung ab?",
    a: "Schreib uns einfach per WhatsApp oder E-Mail – kein Lebenslauf nötig für den ersten Kontakt. Wir laden dich zu einem lockeren Kennenlerngespräch ein (Kaffee geht auf uns ☕)."
  },
  {
    q: "Gibt es die 4-Tage-Woche wirklich?",
    a: "Ja. Es ist ein optionales Modell – wir sprechen es im Erstgespräch durch. Viele unserer Therapeutinnen arbeiten 4 Tage, weil wir glauben: ausgeruhte Therapeuten machen bessere Therapie."
  },
  {
    q: "Sind Berufsanfänger willkommen?",
    a: "Ja, ausdrücklich. Wir bieten strukturiertes Onboarding, kollegiale Fallbesprechungen und übernehmen 100 % der Fortbildungskosten. Du musst kein Profi auf allen Gebieten sein – nur die Bereitschaft zur Entwicklung mitbringen."
  },
  {
    q: "Welche Spezialisierungen gibt es in der Praxis?",
    a: "Wir behandeln in drei Schwerpunkten: Pädiatrie (SES, Wortschatz, Grammatik, LRS), Neurologie (Aphasie, Dysarthrie, Dysphagie) und Stottern/Poltern bei Kindern und Erwachsenen."
  },
  {
    q: "Werden Fortbildungskosten übernommen?",
    a: "Ja, zu 100 %. Ob Zertifikatskurse, Fachkongresse oder Spezialisierungen – wir investieren in deine Weiterbildung, weil sie unseren Patienten zugutekommt."
  },
  {
    q: "Wie gut ist die Praxis mit dem ÖPNV erreichbar?",
    a: "Sehr gut. Die Praxis liegt an der Tonhallenstraße 21, direkt in der Duisburger Innenstadt – 2 Minuten zu Fuß vom Hauptbahnhof Duisburg. S-Bahn, U-Bahn und Fernzüge halten vor der Tür."
  },
  {
    q: "Kann ich in Teilzeit als Logopädin arbeiten?",
    a: "Ja. Wir bieten Stellen ab 20 Stunden pro Woche. Ob Teilzeit, Vollzeit oder 4-Tage-Woche – wir finden gemeinsam ein Modell, das zu deinem Leben passt."
  }
];
---

<section id="faq" class="py-24 bg-slate-50">
  <div class="max-w-3xl mx-auto px-6">
    <div class="text-center mb-6">
      <span class="inline-flex items-center px-3 py-1 rounded-full text-xs font-bold uppercase tracking-widest bg-simsek-green/10 text-simsek-green border border-simsek-green/20 mb-4">
        FAQ
      </span>
    </div>
    <h2 class="text-4xl md:text-5xl font-bold text-slate-900 mb-4 leading-tight text-center">Häufige Fragen zum Logopädie-Job</h2>
    <div class="h-px bg-linear-to-r from-transparent via-simsek-green/40 to-transparent mb-6"></div>
    <p class="text-lg text-slate-600 text-center mb-12">Alles Wichtige auf einen Blick.</p>

    <div class="space-y-4">
      {faqs.map((faq) => (
        <details class="bg-white rounded-2xl border border-slate-100 shadow-sm overflow-hidden group">
          <summary class="w-full text-left px-6 py-5 flex justify-between items-center gap-4 font-semibold text-slate-900 hover:bg-slate-50 transition-colors cursor-pointer list-none">
            <span>{faq.q}</span>
            <svg class="w-5 h-5 text-slate-400 shrink-0 transition-transform duration-200 group-open:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
            </svg>
          </summary>
          <div class="px-6 pb-5">
            <p class="text-slate-600 leading-relaxed">{faq.a}</p>
          </div>
        </details>
      ))}
    </div>

    <div class="mt-12 text-center">
      <p class="text-xl font-bold text-slate-900 mb-4">Noch eine Frage?</p>
      <a href="https://api.whatsapp.com/send?phone=4920334868690&text=Hallo%20Emel!%20Ich%20habe%20eine%20Frage%20zum%20Job." target="_blank" rel="noopener" class="inline-flex items-center gap-2 px-6 py-3 bg-linear-to-r from-simsek-green to-simsek-blue text-white font-bold rounded-full shadow-md shadow-simsek-green/20 hover:shadow-lg hover:shadow-simsek-green/30 hover:scale-[1.03] active:scale-[0.97] transition-all duration-200 no-underline text-sm">
        <svg class="w-4 h-4 shrink-0" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L0 24l6.335-1.662c1.72.937 3.672 1.433 5.662 1.434h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
        Direkt fragen (WhatsApp)
      </a>
    </div>
  </div>
</section>
