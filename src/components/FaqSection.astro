---
const faqs = [
  {
    q: "Welche Stelle bietet die Praxis Şimşek an?",
    a: "Wir suchen eine Logopädin bzw. einen Logopäden (m/w/d) in Vollzeit oder Teilzeit. Die Stelle ist an unserem Standort Tonhallenstraße 21, 47051 Duisburg – nur 2 Minuten vom Hauptbahnhof."
  },
  {
    q: "Wie hoch ist das Gehalt als Logopädin bei Praxis Şimşek?",
    a: "Wir zahlen deutlich über dem NRW-Branchendurchschnitt für Logopädinnen – und das merkt man. Die genaue Zahl besprechen wir im persönlichen Gespräch, abhängig von Erfahrung und Stundenzahl."
  },
  {
    q: "Wie läuft die Bewerbung ab?",
    a: "Schreib uns einfach per WhatsApp oder E-Mail – kein Lebenslauf nötig für den ersten Kontakt. Wir laden dich zu einem lockeren Kennenlerngespräch ein (Kaffee geht auf uns ☕)."
  },
  {
    q: "Gibt es die 4-Tage-Woche wirklich?",
    a: "Ja. Es ist ein optionales Modell – wir sprechen es im Erstgespräch durch. Viele unserer Therapeutinnen arbeiten 4 Tage, weil wir glauben: ausgeruhte Therapeuten machen bessere Therapie."
  },
  {
    q: "Sind Berufsanfänger willkommen?",
    a: "Ja, ausdrücklich. Wir bieten strukturiertes Onboarding, kollegiale Fallbesprechungen und übernehmen 100 % der Fortbildungskosten. Du musst kein Profi auf allen Gebieten sein – nur die Bereitschaft zur Entwicklung mitbringen."
  },
  {
    q: "Welche Spezialisierungen gibt es in der Praxis?",
    a: "Wir behandeln in drei Schwerpunkten: Pädiatrie (SES, Wortschatz, Grammatik, LRS), Neurologie (Aphasie, Dysarthrie, Dysphagie) und Stimmtherapie (ISTP, Lax Vox®). Bilinguales Arbeiten auf Deutsch und Türkisch ist möglich und erwünscht."
  },
  {
    q: "Werden Fortbildungskosten übernommen?",
    a: "Ja, zu 100 %. Ob Zertifikatskurse, Fachkongresse oder Spezialisierungen – wir investieren in deine Weiterbildung, weil sie unseren Patienten zugutekommt."
  },
  {
    q: "Wie gut ist die Praxis mit dem ÖPNV erreichbar?",
    a: "Sehr gut. Die Praxis liegt an der Tonhallenstraße 21, direkt in der Duisburger Innenstadt – 2 Minuten zu Fuß vom Hauptbahnhof Duisburg. S-Bahn, U-Bahn und Fernzüge halten vor der Tür."
  },
  {
    q: "Kann ich in Teilzeit als Logopädin arbeiten?",
    a: "Ja. Wir bieten Stellen ab 20 Stunden pro Woche. Ob Teilzeit, Vollzeit oder 4-Tage-Woche – wir finden gemeinsam ein Modell, das zu deinem Leben passt."
  }
];
---

<section id="faq" class="py-24 bg-slate-50">
  <div class="max-w-3xl mx-auto px-6">
    <h2 class="text-4xl md:text-5xl font-bold text-slate-900 mb-4 uppercase tracking-tight text-center">Häufige Fragen zum Logopädie-Job</h2>
    <p class="text-lg text-slate-600 text-center mb-16">Alles Wichtige auf einen Blick.</p>

    <div class="space-y-4">
      {faqs.map((faq) => (
        <details class="bg-white rounded-2xl border border-slate-100 shadow-sm overflow-hidden group">
          <summary class="w-full text-left px-6 py-5 flex justify-between items-center gap-4 font-semibold text-slate-900 hover:bg-slate-50 transition-colors cursor-pointer list-none">
            <span>{faq.q}</span>
            <svg class="w-5 h-5 text-slate-400 shrink-0 transition-transform duration-200 group-open:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
            </svg>
          </summary>
          <div class="px-6 pb-5">
            <p class="text-slate-600 leading-relaxed">{faq.a}</p>
          </div>
        </details>
      ))}
    </div>

    <div class="mt-12 text-center">
      <p class="text-slate-500 mb-4">Noch eine Frage?</p>
      <a href="https://api.whatsapp.com/send?phone=4920334868690&text=Hallo%20Emel!%20Ich%20habe%20eine%20Frage%20zum%20Job." target="_blank" class="inline-flex items-center gap-2 px-6 py-3 bg-simsek-green text-white font-bold rounded-xl no-underline hover:scale-[1.02] transition-transform text-sm">
        Direkt fragen (WhatsApp)
      </a>
    </div>
  </div>
</section>
