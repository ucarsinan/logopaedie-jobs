---
interface FaqItem {
  q: string;
  a: string;
}
interface Props {
  faq: FaqItem[];
}
const { faq } = Astro.props;
---

<section class="mt-12 pt-8 border-t border-slate-100">
  <h2 class="text-xl font-bold text-slate-900 mb-5 pl-4 border-l-3 border-simsek-green">Häufige Fragen</h2>
  <div class="space-y-3">
    {faq.map((item) => (
      <details class="group border border-slate-100 rounded-2xl overflow-hidden">
        <summary class="flex items-center justify-between gap-4 px-5 py-4 cursor-pointer list-none font-semibold text-slate-800 text-sm hover:bg-slate-50 transition-colors duration-150">
          {item.q}
          <svg class="w-4 h-4 shrink-0 text-slate-400 group-open:rotate-180 transition-transform duration-200" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
          </svg>
        </summary>
        <div class="px-5 pb-4 text-slate-600 text-sm leading-relaxed border-t border-slate-50">
          {item.a}
        </div>
      </details>
    ))}
  </div>
</section>
