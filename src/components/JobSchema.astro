---
// src/components/JobSchema.astro

// 1. Datum: Festes Erstveröffentlichungsdatum (wichtig für Google for Jobs)
const datePosted = "2025-12-18";

// 2. Ablaufdatum fest gesetzt (verhindert Ablauf ohne Rebuild)
const validThrough = "2026-12-31";

// 3. Deine ECHTEN Daten
const jobData = {
  title: "Logopäde / Sprachtherapeut (m/w/d)",
  description: "Werde Teil unseres bilingualen Teams (Deutsch-Türkisch) in Duisburg. Wir bieten Spezialisierungen in Pädiatrie und Neurologie. Genieße eine flexible 4-Tage-Woche, überdurchschnittliches Gehalt und moderne Praxisräume im 3. OG (mit Aufzug) direkt in der Tonhallenstraße 21, nur 2 Min. vom Hbf.",
  orgName: "Praxis für Logopädie Şimşek",
  
  // HIER SIND DIE PLATZHALTER JETZT ERSETZT:
  url: "https://xn--logopdiejobs-kcb.de/",
  logo: "https://xn--logopdiejobs-kcb.de/logo.png", // PNG mind. 112x112px für Google for Jobs
  
  location: {
    city: "Duisburg",
    zip: "47051",
    street: "Tonhallenstraße 21"
  },
};
---

<script type="application/ld+json" is:inline set:html={JSON.stringify({
  "@context": "https://schema.org/",
  "@type": "JobPosting",
  "title": jobData.title,
  "description": jobData.description,
  "identifier": {
    "@type": "PropertyValue",
    "name": jobData.orgName,
    "value": "LOGO-JOB-DUI-01"
  },
  "hiringOrganization": {
    "@type": "Organization",
    "name": jobData.orgName,
    "sameAs": jobData.url,
    "logo": jobData.logo
  },
  "jobLocation": {
    "@type": "Place",
    "address": {
      "@type": "PostalAddress",
      "streetAddress": jobData.location.street,
      "addressLocality": jobData.location.city,
      "postalCode": jobData.location.zip,
      "addressRegion": "Nordrhein-Westfalen",
      "addressCountry": "DE"
    }
  },
  "datePosted": datePosted,
  "validThrough": validThrough,
  "employmentType": ["FULL_TIME", "PART_TIME"],
  "directApply": true,
  "jobBenefits": "4-Tage-Woche möglich, 100% Fortbildungskosten, zentrale Lage am Hbf, modernes Material, bilinguales Team",
  "responsibilities": "Durchführung logopädischer Diagnostik und Therapie in den Bereichen Pädiatrie (SES, Wortschatz, Grammatik, LRS) und Neurologie (Aphasie, Dysarthrie, Dysphagie). Bilinguales Arbeiten in Deutsch und Türkisch möglich.",
  "workHours": "20–40 Stunden pro Woche (Vollzeit oder Teilzeit möglich)",
  "employerOverview": "Praxis für Logopädie Şimşek ist eine spezialisierte Praxis in Duisburg mit einem bilingualen Team (Deutsch-Türkisch). Schwerpunkte: Pädiatrie und Neurologie. Zentrale Lage direkt am Duisburger Hauptbahnhof.",
  "occupationalCategory": "29-1127.00"
})} />

<script type="application/ld+json" is:inline set:html={JSON.stringify({
  "@context": "https://schema.org",
  "@type": "MedicalOrganization",
  "name": "Praxis für Logopädie Şimşek",
  "url": "https://xn--logopdiejobs-kcb.de/",
  "logo": "https://xn--logopdiejobs-kcb.de/logo.png",
  "description": "Spezialisierte Logopädie-Praxis in Duisburg mit bilingualen Team (Deutsch-Türkisch). Schwerpunkte: Pädiatrie und Neurologie.",
  "medicalSpecialty": [
    "Sprachtherapie",
    "Pädiatrische Logopädie",
    "Neurologische Rehabilitation"
  ],
  "address": {
    "@type": "PostalAddress",
    "streetAddress": "Tonhallenstraße 21",
    "addressLocality": "Duisburg",
    "postalCode": "47051",
    "addressRegion": "Nordrhein-Westfalen",
    "addressCountry": "DE"
  },
  "telephone": "+492033486690",
  "email": "info@logopaedie-simsek.de",
  "employee": {
    "@type": "Person",
    "name": "Emel Şimşek-Uçar",
    "jobTitle": "Staatlich anerkannte Logopädin, Praxisinhaberin"
  },
  "hasOfferCatalog": {
    "@type": "OfferCatalog",
    "name": "Logopädische Leistungen",
    "itemListElement": [
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Pädiatrische Logopädie (SES, LRS, Wortschatz)" } },
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Neurologische Sprachtherapie (Aphasie, Dysarthrie, Dysphagie)" } },
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Bilinguale Therapie Deutsch-Türkisch" } }
    ]
  }
})} />