---
// src/components/JobSchema.astro

// 1. Datum: Festes Erstveröffentlichungsdatum (wichtig für Google for Jobs)
const datePosted = "2025-12-18";

// 2. Ablaufdatum fest gesetzt (verhindert Ablauf ohne Rebuild)
const validThrough = "2026-12-31";

// 3. Deine ECHTEN Daten
const jobData = {
  title: "Logopäde / Sprachtherapeut (m/w/d)",
  description: "Werde Teil unseres bilingualen Teams (Deutsch-Türkisch) in Duisburg. Wir bieten Spezialisierungen in Pädiatrie, Neurologie und Stimmtherapie (ISTP, Lax Vox®). Genieße eine flexible 4-Tage-Woche, Top-Gehalt und moderne Praxisräume im 3. OG (mit Aufzug) direkt in der Tonhallenstraße 21, nur 2 Min. vom Hbf.",
  orgName: "Praxis für Logopädie Şimşek",
  
  // HIER SIND DIE PLATZHALTER JETZT ERSETZT:
  url: "https://xn--logopdiejobs-kcb.de/",
  logo: "https://xn--logopdiejobs-kcb.de/logo.png", // PNG mind. 112x112px für Google for Jobs
  
  location: {
    city: "Duisburg",
    zip: "47051",
    street: "Tonhallenstraße 21"
  },
  salary: {
    min: 3800,
    max: 5200, 
    currency: "EUR"
  }
};
---

<script type="application/ld+json" is:inline set:html={JSON.stringify({
  "@context": "https://schema.org/",
  "@type": "JobPosting",
  "title": jobData.title,
  "description": jobData.description,
  "identifier": {
    "@type": "PropertyValue",
    "name": jobData.orgName,
    "value": "LOGO-JOB-DUI-01"
  },
  "hiringOrganization": {
    "@type": "Organization",
    "name": jobData.orgName,
    "sameAs": jobData.url,
    "logo": jobData.logo
  },
  "jobLocation": {
    "@type": "Place",
    "address": {
      "@type": "PostalAddress",
      "streetAddress": jobData.location.street,
      "addressLocality": jobData.location.city,
      "postalCode": jobData.location.zip,
      "addressRegion": "Nordrhein-Westfalen",
      "addressCountry": "DE"
    }
  },
  "baseSalary": {
    "@type": "MonetaryAmount",
    "currency": jobData.salary.currency,
    "value": {
      "@type": "QuantitativeValue",
      "minValue": jobData.salary.min,
      "maxValue": jobData.salary.max,
      "unitText": "MONTH"
    }
  },
  "datePosted": datePosted,
  "validThrough": validThrough,
  "employmentType": ["FULL_TIME", "PART_TIME"],
  "directApply": true,
  "jobBenefits": "4-Tage-Woche möglich, 100% Fortbildungskosten, zentrale Lage am Hbf, modernes Material, bilinguales Team",
  "responsibilities": "Durchführung logopädischer Diagnostik und Therapie in den Bereichen Pädiatrie (SES, Wortschatz, Grammatik, LRS), Neurologie (Aphasie, Dysarthrie, Dysphagie) und Stimmtherapie (ISTP, Lax Vox®). Bilinguales Arbeiten in Deutsch und Türkisch möglich.",
  "workHours": "20–40 Stunden pro Woche (Vollzeit oder Teilzeit möglich)",
  "employerOverview": "Praxis für Logopädie Şimşek ist eine spezialisierte Praxis in Duisburg mit einem bilingualen Team (Deutsch-Türkisch). Schwerpunkte: Pädiatrie, Neurologie und Stimmtherapie. Zentrale Lage direkt am Duisburger Hauptbahnhof.",
  "occupationalCategory": "29-1127.00"
})} />