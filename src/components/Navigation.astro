---
import Logo from './Logo.astro';

const { pathname } = Astro.url;

const isHome = pathname === '/';

const anchorLinks = [
  { href: '/#aufgaben', label: 'Was dich erwartet' },
  { href: '/#anforderungen', label: 'Anforderungen' },
  { href: '/#benefits', label: 'Vorteile' },
];

const pageLinks = [
  { href: '/ratgeber/', label: 'Ratgeber', active: pathname.startsWith('/ratgeber') },
  { href: '/gehaltsrechner/', label: 'Gehaltsrechner', active: pathname === '/gehaltsrechner/' || pathname.startsWith('/gehaltsrechner') },
];

const linkClass = (active: boolean) => [
  'px-4 py-2 text-[13px] font-semibold rounded-full transition-all duration-200 no-underline border-b-2',
  active
    ? 'border-simsek-green text-slate-900 bg-simsek-green/5'
    : 'border-transparent text-slate-500 hover:text-slate-900 hover:bg-slate-50',
].join(' ');
---

<nav class="sticky top-0 z-50 bg-white/95 backdrop-blur-md border-b border-slate-100/80">
  <!-- Accent stripe -->
  <div class="absolute top-0 left-0 right-0 h-[2px] bg-linear-to-r from-simsek-green via-simsek-blue to-simsek-green"></div>

  <div class="max-w-7xl mx-auto px-6 h-[68px] flex items-center justify-between">

    <!-- Logo -->
    <a href="/" class="block shrink-0 hover:opacity-85 transition-opacity duration-200" aria-label="Zur Startseite">
      <Logo class="h-10 md:h-11 w-auto" />
    </a>

    <!-- Desktop Nav -->
    <div class="hidden md:flex items-center gap-1">
      <!-- Home — always visible -->
      <a href="/" class={linkClass(isHome)}>Home</a>

      {isHome && anchorLinks.map(link => (
        <a href={link.href} class={linkClass(false)}>{link.label}</a>
      ))}
      {!isHome && pageLinks.map(link => (
        <a href={link.href} class={linkClass(link.active)}>{link.label}</a>
      ))}
    </div>

    <!-- Desktop Right -->
    <div class="hidden md:flex items-center gap-4">
      <a
        href="https://logopaedie-simsek.de"
        target="_blank"
        rel="noopener noreferrer"
        class="text-[12px] font-semibold text-slate-400 hover:text-slate-600 transition-colors duration-150 no-underline"
      >
        Zur Praxis ↗
      </a>
      <a
        href="/#apply"
        class="inline-flex items-center gap-1.5 px-5 py-2.5 bg-linear-to-r from-simsek-green to-simsek-blue text-white text-[13px] font-bold rounded-full shadow-md shadow-simsek-green/20 hover:shadow-lg hover:shadow-simsek-green/30 hover:scale-[1.03] active:scale-[0.97] transition-all duration-200 no-underline"
      >
        Jetzt bewerben
        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M13 7l5 5m0 0l-5 5m5-5H6" />
        </svg>
      </a>
    </div>

    <!-- Mobile: CTA + Hamburger -->
    <div class="flex md:hidden items-center gap-2.5">
      <a
        href="/#apply"
        class="inline-flex items-center gap-1 px-4 py-2 bg-linear-to-r from-simsek-green to-simsek-blue text-white text-[13px] font-bold rounded-full shadow-sm no-underline"
      >
        Bewerben
        <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M13 7l5 5m0 0l-5 5m5-5H6" />
        </svg>
      </a>
      <button
        id="mobile-menu-btn"
        aria-label="Menü öffnen"
        class="p-2 rounded-xl hover:bg-slate-100 transition-colors duration-150 text-slate-600"
      >
        <svg id="icon-open" class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
        <svg id="icon-close" class="w-5 h-5 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
    </div>

  </div>

  <!-- Mobile Menu -->
  <div id="mobile-menu" class="hidden md:hidden border-t border-slate-100 bg-white/98">
    <div class="max-w-7xl mx-auto px-4 py-3 space-y-0.5">

      <a
        href="/"
        class={[
          'mobile-nav-link flex items-center gap-2 py-3 px-4 text-[13px] font-semibold rounded-xl no-underline transition-all duration-150',
          isHome ? 'bg-simsek-green/10 text-simsek-green' : 'text-slate-700 hover:bg-slate-50',
        ].join(' ')}
      >
        <span class={['w-1.5 h-1.5 rounded-full shrink-0', isHome ? 'bg-simsek-green' : 'bg-slate-300'].join(' ')}></span>
        Home
      </a>

      {isHome && anchorLinks.map(link => (
        <a href={link.href} class="mobile-nav-link flex items-center gap-2 py-3 px-4 text-[13px] font-semibold text-slate-700 hover:bg-slate-50 rounded-xl no-underline transition-colors duration-150">
          <span class="w-1.5 h-1.5 rounded-full bg-slate-300 shrink-0"></span>
          {link.label}
        </a>
      ))}
      {!isHome && pageLinks.map(link => (
        <a
          href={link.href}
          class={[
            'mobile-nav-link flex items-center gap-2 py-3 px-4 text-[13px] font-semibold rounded-xl no-underline transition-all duration-150',
            link.active ? 'bg-simsek-green/10 text-simsek-green' : 'text-slate-700 hover:bg-slate-50',
          ].join(' ')}
        >
          <span class={['w-1.5 h-1.5 rounded-full shrink-0', link.active ? 'bg-simsek-green' : 'bg-slate-300'].join(' ')}></span>
          {link.label}
        </a>
      ))}

      <div class="pt-2 mt-1 border-t border-slate-100 pb-2">
        <a
          href="https://logopaedie-simsek.de"
          target="_blank"
          rel="noopener noreferrer"
          class="flex items-center gap-2 py-3 px-4 text-[13px] font-semibold text-simsek-green hover:bg-slate-50 rounded-xl no-underline transition-colors duration-150"
        >
          <span class="w-1.5 h-1.5 rounded-full bg-simsek-green shrink-0"></span>
          Zur Praxis →
        </a>
      </div>

    </div>
  </div>
</nav>

<script is:inline>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  const iconOpen = document.getElementById('icon-open');
  const iconClose = document.getElementById('icon-close');

  btn.addEventListener('click', () => {
    const isOpen = !menu.classList.contains('hidden');
    menu.classList.toggle('hidden', isOpen);
    iconOpen.classList.toggle('hidden', !isOpen);
    iconClose.classList.toggle('hidden', isOpen);
  });

  document.querySelectorAll('.mobile-nav-link').forEach(link => {
    link.addEventListener('click', () => {
      menu.classList.add('hidden');
      iconOpen.classList.remove('hidden');
      iconClose.classList.add('hidden');
    });
  });
</script>
