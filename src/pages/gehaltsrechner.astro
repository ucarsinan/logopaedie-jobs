---
import Layout from '../layouts/Layout.astro';
import Navigation from '../components/Navigation.astro';
import Footer from '../components/Footer.astro';
import Gehaltsrechner from '../components/Gehaltsrechner.astro';

const pageTitle = "Gehaltsrechner Logopädie NRW 2026 — Was verdienst du wirklich?";
const pageDescription = "Interaktiver Gehaltsrechner für Logopädinnen und Sprachtherapeuten in NRW. Berufserfahrung, Setting, Qualifikation, Region — individuell kalkuliert. Inkl. Methodik und Quellen.";
---

<Layout title={pageTitle} description={pageDescription} breadcrumbs={[
  { name: "Startseite", url: "https://xn--logopdiejobs-kcb.de/" },
  { name: "Gehaltsrechner", url: "https://xn--logopdiejobs-kcb.de/gehaltsrechner/" }
]}>
  <script slot="head" type="application/ld+json" is:inline set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "Gehaltsrechner Logopädie NRW",
    "description": "Interaktiver Gehaltsrechner für Logopädinnen und Sprachtherapeuten in NRW. Basiert auf öffentlich verfügbaren Gehaltsdaten für 2025/2026.",
    "url": "https://xn--logopdiejobs-kcb.de/gehaltsrechner/",
    "applicationCategory": "FinanceApplication",
    "operatingSystem": "Web",
    "inLanguage": "de",
    "isAccessibleForFree": true,
    "offers": {
      "@type": "Offer",
      "price": "0",
      "priceCurrency": "EUR"
    },
    "author": {
      "@type": "Organization",
      "name": "Logopädiejobs.de",
      "url": "https://xn--logopdiejobs-kcb.de/"
    }
  })} />

  <Navigation />
  <main>
    <article class="max-w-4xl mx-auto px-4 sm:px-6 py-10 md:py-24 overflow-x-hidden">
      <header class="mb-12">
        <span class="inline-flex items-center px-3 py-1 rounded-full text-xs font-bold uppercase tracking-widest bg-simsek-blue/10 text-simsek-blue border border-simsek-blue/20 mb-6">
          Tools
        </span>
        <h1 class="text-2xl sm:text-4xl md:text-5xl font-bold text-slate-900 leading-tight mb-6">
          Gehaltsrechner Logopädie NRW
        </h1>
        <p class="text-xl text-slate-600 leading-relaxed">
          Stell deine Eckdaten ein und sieh in Echtzeit, was als Logopädin oder Sprachtherapeut in Nordrhein-Westfalen realistisch drin ist. Basiert auf öffentlich verfügbaren Gehaltsdaten für 2025/2026.
        </p>
        <div class="mt-8 h-px bg-linear-to-r from-simsek-green via-simsek-blue/40 to-transparent"></div>
      </header>

      <Gehaltsrechner />

      <section class="mt-16">
        <h2 class="text-2xl md:text-3xl font-bold text-slate-900 mb-6 pl-4 border-l-4 border-simsek-green">Methodik & Quellen</h2>
        <div class="space-y-4 text-slate-600 leading-relaxed">
          <p>
            Der Rechner kombiniert den NRW-Medianwert für staatlich anerkannte Logopädinnen in freier Praxis (Vollzeit, 38,5 Stunden) mit multiplikativen Modifikatoren für Setting, Qualifikation, Schwerpunkt, Region und Arbeitszeit. Die ausgegebene Spanne spiegelt eine typische Streuung von ±8 % wider — einzelne Arbeitgeber können darüber oder darunter liegen.
          </p>
          <p class="font-semibold text-slate-800">Datenquellen:</p>
          <ul class="space-y-2 pl-0">
            <li class="flex items-start gap-2.5 text-sm"><span class="mt-1.5 w-1.5 h-1.5 rounded-full bg-simsek-green shrink-0"></span>Bundesagentur für Arbeit, Entgeltatlas für die Berufsgruppe 81724 (Logopädie), Stand 2025</li>
            <li class="flex items-start gap-2.5 text-sm"><span class="mt-1.5 w-1.5 h-1.5 rounded-full bg-simsek-green shrink-0"></span>jobvector Gehaltsreport Logopädie 2025 (NRW-Median: 45.850 €/Jahr)</li>
            <li class="flex items-start gap-2.5 text-sm"><span class="mt-1.5 w-1.5 h-1.5 rounded-full bg-simsek-green shrink-0"></span>StepStone Gehaltsreport Gesundheitswesen 2025</li>
            <li class="flex items-start gap-2.5 text-sm"><span class="mt-1.5 w-1.5 h-1.5 rounded-full bg-simsek-green shrink-0"></span>dbl-Praxisumfrage 2024/2025 zu freien Praxen</li>
            <li class="flex items-start gap-2.5 text-sm"><span class="mt-1.5 w-1.5 h-1.5 rounded-full bg-simsek-green shrink-0"></span>TVöD-VKA Entgeltgruppe 9a als Referenz für das Klinik-Setting</li>
          </ul>
          <p>
            Der Rechner ist eine Schätzung, kein verbindliches Angebot. Steuerklasse, Bundesland, Kinderfreibetrag und individuelle Verhandlung werden nicht abgebildet. Wer ein konkretes Angebot vergleichen will, sollte den Bruttowert und alle Zusatzleistungen zusammen betrachten — nicht nur das Monatsgehalt.
          </p>
        </div>
      </section>

      <section class="mt-16">
        <h2 class="text-2xl md:text-3xl font-bold text-slate-900 mb-6 pl-4 border-l-4 border-simsek-blue">Warum die Zahlen so auseinandergehen</h2>
        <div class="space-y-4 text-slate-600 leading-relaxed">
          <p>
            Wenn du online nach "Gehalt Logopädie" suchst, bekommst du Zahlen zwischen 2.100 € und 4.500 € brutto — eine Spanne, die fast nichts aussagt. Der Grund: die Daten werden aus unterschiedlichen Quellen (Praxen, Kliniken, Berufsanfänger, erfahrene Therapeutinnen) zusammengewürfelt, und regionale Unterschiede werden oft ignoriert.
          </p>
          <p>
            NRW liegt beim Logopädie-Gehalt über dem Bundesschnitt. Das hat mehrere Gründe: hohe Nachfrage in Ballungsräumen, Fachkräftemangel und starke Konkurrenz um qualifizierte Therapeutinnen. Wer verhandelt, kann oft mehr rausholen als die Einstiegszahlen vermuten lassen.
          </p>
          <p>
            Lies dazu auch: <a href="/berufshandbuch/gehalt-logopaedie-nrw/" class="text-simsek-blue font-semibold hover:text-simsek-green transition-colors underline underline-offset-2">Logopädie Gehalt NRW 2026 — der vollständige Überblick</a>.
          </p>
        </div>
      </section>

      <!-- CTA Box -->
      <div class="mt-16 p-px rounded-3xl bg-linear-to-br from-simsek-green to-simsek-blue">
        <div class="bg-white rounded-[calc(1.5rem-1px)] p-8">
          <p class="text-xs font-bold uppercase tracking-widest text-simsek-green mb-3">Praxis Şimşek · Duisburg</p>
          <h2 class="text-2xl font-bold text-slate-900 mb-3">Gehalt über dem NRW-Schnitt in Duisburg</h2>
          <p class="text-slate-600 mb-6 text-sm leading-relaxed">
            Die Praxis für Logopädie Şimşek zahlt bewusst über dem regionalen Durchschnitt. Dazu: 100 % Fortbildungsübernahme, optionale 4-Tage-Woche und kollegiale Fallbesprechungen.
          </p>
          <a
            href="https://api.whatsapp.com/send?phone=4920334868690&text=Hallo%20Emel!%20Ich%20interessiere%20mich%20f%C3%BCr%20den%20Job."
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 px-5 py-2.5 bg-linear-to-r from-simsek-green to-simsek-blue text-white text-sm font-bold rounded-full shadow-md shadow-simsek-green/20 hover:shadow-lg hover:shadow-simsek-green/30 hover:scale-[1.03] active:scale-[0.97] transition-all duration-200 no-underline"
          >
            <svg class="w-4 h-4 shrink-0" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L0 24l6.335-1.662c1.72.937 3.672 1.433 5.662 1.434h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            Jetzt per WhatsApp bewerben
          </a>
        </div>
      </div>

      <footer class="mt-12 pt-8 border-t border-slate-100">
        <p class="text-xs text-slate-400">
          Stand: April 2026. Der Rechner wird bei neuen Gehaltsdaten aktualisiert. Keine Steuerberatung, keine Rechtsberatung.
        </p>
      </footer>
    </article>
  </main>
  <Footer />
</Layout>
