---
import Layout from '../layouts/Layout.astro';
import Navigation from '../components/Navigation.astro';
import Footer from '../components/Footer.astro';
---

<Layout
  title="Seite nicht gefunden | Logopädie Jobs Duisburg"
  description="Diese Seite existiert nicht. Zurück zur Stellenanzeige für Logopädinnen und Sprachtherapeuten in Duisburg."
>
  <Navigation />
  <main class="max-w-3xl mx-auto px-6 py-32 text-center">
    <span class="inline-flex items-center px-3 py-1 rounded-full text-xs font-bold uppercase tracking-widest bg-simsek-green/10 text-simsek-green border border-simsek-green/20 mb-6">
      404
    </span>
    <h1 class="text-5xl md:text-6xl font-bold text-slate-900 mb-6 leading-tight">
      Seite nicht gefunden
    </h1>
    <p class="text-lg text-slate-600 mb-10 max-w-md mx-auto leading-relaxed">
      Diese Seite existiert nicht – aber unsere offene Stelle für Logopädinnen in Duisburg schon.
    </p>
    <a
      href="/"
      class="inline-flex items-center gap-2 px-6 py-3 bg-linear-to-r from-simsek-green to-simsek-blue text-white font-bold rounded-full shadow-md shadow-simsek-green/20 hover:shadow-lg hover:shadow-simsek-green/30 hover:scale-[1.03] active:scale-[0.97] transition-all duration-200 no-underline"
    >
      Zur Stellenanzeige
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
    </a>
  </main>
  <Footer />
</Layout>
