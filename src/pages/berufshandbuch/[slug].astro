---
import { getCollection, render, type CollectionEntry } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import Navigation from '../../components/Navigation.astro';
import Footer from '../../components/Footer.astro';
import DefinitionBox from '../../components/DefinitionBox.astro';
import FAQBlock from '../../components/FAQBlock.astro';

export async function getStaticPaths() {
  const beitraege = await getCollection('ratgeber', ({ data }) => !data.draft);
  return beitraege.map((beitrag) => ({
    params: { slug: beitrag.id },
    props: { beitrag },
  }));
}

type Props = { beitrag: CollectionEntry<'ratgeber'> };
const { beitrag } = Astro.props;
const { Content } = await render(beitrag);
const pubDateFormatiert = beitrag.data.pubDate.toLocaleDateString('de-DE', {
  day: '2-digit', month: 'long', year: 'numeric',
});

const kategorieColors: Record<string, string> = {
  'Karriere':    'bg-simsek-green/10 text-simsek-green border-simsek-green/20',
  'Gehalt':      'bg-simsek-blue/10 text-simsek-blue border-simsek-blue/20',
  'Arbeitszeit': 'bg-amber-50 text-amber-700 border-amber-200',
  'Fachwissen':  'bg-violet-50 text-violet-700 border-violet-200',
  'Duisburg / NRW': 'bg-slate-100 text-slate-700 border-slate-200',
};
const badgeClass = kategorieColors[beitrag.data.kategorie] ?? 'bg-slate-100 text-slate-600 border-slate-200';

const canonicalURL = `https://xn--logopdiejobs-kcb.de/berufshandbuch/${beitrag.id}/`;

const alleArtikel = await getCollection('ratgeber', ({ data }) => !data.draft);
const verwandteArtikel = beitrag.data.relatedArticles
  ? alleArtikel.filter(a => beitrag.data.relatedArticles!.includes(a.id))
  : [];
const articleSchema = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": beitrag.data.title,
  "description": beitrag.data.description,
  "datePublished": beitrag.data.pubDate.toISOString(),
  "dateModified": (beitrag.data.updatedDate ?? beitrag.data.pubDate).toISOString(),
  "author": {
    "@type": "Person",
    "name": beitrag.data.author
  },
  "publisher": {
    "@type": "Organization",
    "name": "Logopädiejobs.de",
    "logo": {
      "@type": "ImageObject",
      "url": "https://xn--logopdiejobs-kcb.de/logo.svg"
    }
  },
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": canonicalURL
  },
  ...(beitrag.data.heroImage ? { "image": `https://xn--logopdiejobs-kcb.de${beitrag.data.heroImage}` } : {}),
  "speakable": {
    "@type": "SpeakableSpecification",
    "cssSelector": ["h1", ".article-description"]
  }
};

const faqSchema = beitrag.data.faq ? {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": beitrag.data.faq.map(item => ({
    "@type": "Question",
    "name": item.q,
    "acceptedAnswer": { "@type": "Answer", "text": item.a }
  }))
} : null;
---

<Layout
  title={`${beitrag.data.title} | Logopädiejobs.de`}
  description={beitrag.data.description}
  ogImage={beitrag.data.heroImage}
  breadcrumbs={[
    { name: "Startseite", url: "https://xn--logopdiejobs-kcb.de/" },
    { name: "Berufshandbuch", url: "https://xn--logopdiejobs-kcb.de/berufshandbuch/" },
    { name: beitrag.data.title, url: canonicalURL },
  ]}
>
  <script slot="head" type="application/ld+json" is:inline set:html={JSON.stringify(articleSchema)} />
  {faqSchema && <script slot="head" type="application/ld+json" is:inline set:html={JSON.stringify(faqSchema)} />}
  <Navigation />

  <!-- Reading progress bar -->
  <div
    id="reading-progress"
    class="fixed top-0 left-0 h-0.5 bg-linear-to-r from-simsek-green to-simsek-blue z-50 transition-[width] duration-100 ease-out pointer-events-none"
    style="width: 0%"
    role="progressbar"
    aria-label="Lesefortschritt"
  ></div>

  <main>
    <article class="max-w-3xl mx-auto px-6 py-16 md:py-24">

      <!-- Breadcrumb -->
      <nav class="flex items-center gap-2 text-xs text-slate-400 mb-10 font-medium flex-wrap" aria-label="Breadcrumb">
        <a href="/" class="hover:text-simsek-green transition-colors duration-150 no-underline">Startseite</a>
        <svg class="w-3 h-3 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
        <a href="/berufshandbuch/" class="hover:text-simsek-green transition-colors duration-150 no-underline">Berufshandbuch</a>
        <svg class="w-3 h-3 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
        <span class="text-slate-600 truncate max-w-[200px]">{beitrag.data.title}</span>
      </nav>

      <!-- Article header -->
      <header class="mb-12">
        <span class={`inline-flex items-center px-3 py-1 rounded-full text-xs font-bold uppercase tracking-widest border mb-6 ${badgeClass}`}>
          {beitrag.data.kategorie}
        </span>

        <h1 class="text-4xl md:text-5xl font-bold text-slate-900 leading-tight mb-6">
          {beitrag.data.title}
        </h1>

        <p class="article-description text-xl text-slate-600 leading-relaxed mb-8">
          {beitrag.data.description}
        </p>

        <!-- Author / date row -->
        <div class="flex items-center gap-3">
          <div class="w-9 h-9 rounded-full bg-linear-to-br from-simsek-green/20 to-simsek-blue/20 flex items-center justify-center font-bold text-xs text-simsek-green shrink-0">
            {beitrag.data.author.charAt(0).toUpperCase()}
          </div>
          <div class="text-sm">
            <span class="font-semibold text-slate-700">{beitrag.data.author}</span>
            <span class="mx-1.5 text-slate-300">·</span>
            <span class="text-slate-500">{pubDateFormatiert}</span>
          </div>
        </div>

        <!-- Gradient divider -->
        <div class="mt-8 h-px bg-linear-to-r from-simsek-green via-simsek-blue/40 to-transparent"></div>
      </header>

      <!-- Hero image -->
      {beitrag.data.heroImage && (
        <img
          src={beitrag.data.heroImage}
          alt={beitrag.data.heroImageAlt || beitrag.data.title}
          class="w-full rounded-2xl mb-12 shadow-sm"
        />
      )}

      <!-- Definition box (AI SEO / speakable anchor) -->
      {beitrag.data.definition && <DefinitionBox definition={beitrag.data.definition} />}

      <!-- Article body -->
      <div class="article-body">
        <Content />
      </div>

      <!-- FAQ accordion -->
      {beitrag.data.faq && <FAQBlock faq={beitrag.data.faq} />}

      <!-- Related Articles -->
      {verwandteArtikel.length > 0 && (
        <aside class="mt-14 pt-8 border-t border-slate-100">
          <h3 class="text-xs font-bold uppercase tracking-widest text-slate-400 mb-5">Weitere Artikel</h3>
          <ul class="space-y-3 list-none p-0">
            {verwandteArtikel.map((a) => (
              <li>
                <a
                  href={`/berufshandbuch/${a.id}/`}
                  class="flex items-center justify-between gap-4 p-4 rounded-2xl border border-slate-100 bg-white hover:border-simsek-green/30 hover:shadow-sm hover:shadow-simsek-green/10 transition-all duration-200 no-underline group"
                >
                  <div class="min-w-0">
                    <span class={`inline-flex items-center px-2 py-0.5 rounded-full text-[10px] font-bold uppercase tracking-widest border mb-1 ${kategorieColors[a.data.kategorie] ?? 'bg-slate-100 text-slate-600 border-slate-200'}`}>
                      {a.data.kategorie}
                    </span>
                    <p class="text-sm font-semibold text-slate-800 leading-snug">{a.data.title}</p>
                  </div>
                  <svg class="w-4 h-4 shrink-0 text-slate-300 group-hover:text-simsek-green transition-colors duration-200" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
                  </svg>
                </a>
              </li>
            ))}
          </ul>
        </aside>
      )}

      <!-- CTA Box -->
      <div class="mt-16 p-px rounded-3xl bg-linear-to-br from-simsek-green to-simsek-blue">
        <div class="bg-white rounded-[calc(1.5rem-1px)] p-8">
          <p class="text-xs font-bold uppercase tracking-widest text-simsek-green mb-3">Praxis Şimşek · Duisburg</p>
          <h3 class="text-2xl font-bold text-slate-900 mb-3">Klingt interessant? Wir suchen Verstärkung.</h3>
          <p class="text-slate-600 leading-relaxed mb-6 text-sm">
            Werde Teil eines kollegialen Teams in zentraler Lage — direkt am Duisburger Hauptbahnhof. 4-Tage-Woche möglich.
          </p>
          <a
            href="https://api.whatsapp.com/send?phone=4920334868690&text=Hallo%20Emel!%20Ich%20interessiere%20mich%20f%C3%BCr%20den%20Job."
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 px-5 py-2.5 bg-linear-to-r from-simsek-green to-simsek-blue text-white text-sm font-bold rounded-full shadow-md shadow-simsek-green/20 hover:shadow-lg hover:shadow-simsek-green/30 hover:scale-[1.03] active:scale-[0.97] transition-all duration-200 no-underline"
          >
            <svg class="w-4 h-4 shrink-0" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L0 24l6.335-1.662c1.72.937 3.672 1.433 5.662 1.434h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            Per WhatsApp bewerben
          </a>
        </div>
      </div>

      <!-- Article footer -->
      <footer class="mt-8 pt-6 border-t border-slate-100">
        <p class="text-xs text-slate-400">
          Stand: {pubDateFormatiert}. Redaktionell gepflegt vom Team der Praxis für Logopädie Şimşek.
        </p>
      </footer>

    </article>
  </main>

  <Footer />
</Layout>

<style>
  /* ─── Article body typography ─────────────────────────────────────────────── */

  :global(.article-body) {
    font-size: 1.0625rem;
    line-height: 1.8;
    color: #334155; /* slate-700 */
  }

  :global(.article-body p) {
    margin-bottom: 1.5rem;
  }

  /* H2: simsek-green left accent bar */
  :global(.article-body h2) {
    font-size: 1.5rem;
    font-weight: 700;
    color: #0f172a; /* slate-900 */
    margin-top: 3rem;
    margin-bottom: 1.25rem;
    padding-left: 1rem;
    border-left: 3px solid rgb(129 183 40);
    line-height: 1.3;
  }

  /* H3: simsek-blue left accent bar */
  :global(.article-body h3) {
    font-size: 1.25rem;
    font-weight: 700;
    color: #1e293b; /* slate-800 */
    margin-top: 2rem;
    margin-bottom: 1rem;
    padding-left: 0.875rem;
    border-left: 2px solid rgb(36 135 193);
    line-height: 1.35;
  }

  /* H4 */
  :global(.article-body h4) {
    font-size: 1.0625rem;
    font-weight: 700;
    color: #1e293b;
    margin-top: 1.5rem;
    margin-bottom: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    font-size: 0.75rem;
    color: #64748b; /* slate-500 */
  }

  /* Unordered list */
  :global(.article-body ul) {
    list-style: none;
    padding-left: 0;
    margin-bottom: 1.5rem;
  }

  :global(.article-body ul li) {
    position: relative;
    padding-left: 1.5rem;
    margin-bottom: 0.5rem;
  }

  :global(.article-body ul li::before) {
    content: '';
    position: absolute;
    left: 0;
    top: 0.58em;
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: rgb(129 183 40); /* simsek-green */
  }

  /* Ordered list */
  :global(.article-body ol) {
    list-style: none;
    padding-left: 0;
    margin-bottom: 1.5rem;
    counter-reset: ol-counter;
  }

  :global(.article-body ol li) {
    position: relative;
    padding-left: 2rem;
    margin-bottom: 0.5rem;
    counter-increment: ol-counter;
  }

  :global(.article-body ol li::before) {
    content: counter(ol-counter) '.';
    position: absolute;
    left: 0;
    top: 0;
    font-weight: 700;
    font-size: 0.875rem;
    color: rgb(129 183 40); /* simsek-green */
    line-height: 1.8;
  }

  /* Bold inside list items → simsek-blue */
  :global(.article-body li strong) {
    color: rgb(36 135 193); /* simsek-blue */
    font-weight: 600;
  }

  /* Blockquote */
  :global(.article-body blockquote) {
    border-left: 4px solid rgb(129 183 40);
    background: rgb(129 183 40 / 0.06);
    padding: 1.25rem 1.5rem;
    border-radius: 0 0.75rem 0.75rem 0;
    margin: 2rem 0;
  }

  :global(.article-body blockquote p) {
    margin-bottom: 0;
    font-style: italic;
    color: #475569; /* slate-600 */
  }

  /* Horizontal rule — gradient line */
  :global(.article-body hr) {
    border: none;
    height: 1px;
    background: linear-gradient(to right, rgb(129 183 40), rgb(36 135 193 / 0.4), transparent);
    margin: 3rem 0;
  }

  /* Links */
  :global(.article-body a) {
    color: rgb(36 135 193); /* simsek-blue */
    text-decoration: underline;
    text-underline-offset: 3px;
    font-weight: 500;
    transition: color 0.15s;
  }

  :global(.article-body a:hover) {
    color: rgb(129 183 40); /* simsek-green */
  }

  /* Bold text */
  :global(.article-body strong) {
    font-weight: 600;
    color: #0f172a; /* slate-900 */
  }

  /* Inline code */
  :global(.article-body code) {
    background: rgb(129 183 40 / 0.1);
    color: rgb(36 135 193);
    padding: 0.125rem 0.375rem;
    border-radius: 0.25rem;
    font-size: 0.875em;
    font-family: ui-monospace, 'Cascadia Code', monospace;
  }

  /* First paragraph — slightly larger lead */
  :global(.article-body > p:first-of-type) {
    font-size: 1.125rem;
    color: #475569; /* slate-600 */
    line-height: 1.75;
  }
</style>

<script is:inline>
  // Reading progress bar
  const bar = document.getElementById('reading-progress');
  const article = document.querySelector('article');

  function updateProgress() {
    if (!bar || !article) return;
    const rect = article.getBoundingClientRect();
    const total = article.scrollHeight - window.innerHeight;
    const scrolled = Math.max(0, -rect.top);
    const pct = total > 0 ? Math.min(100, (scrolled / total) * 100) : 0;
    bar.style.width = pct + '%';
  }

  window.addEventListener('scroll', updateProgress, { passive: true });
  updateProgress();
</script>
