                <p class="text-sm text-slate-600 leading-relaxed">{link.text}</p>
                <span class="mt-4 inline-flex text-xs font-bold uppercase tracking-widest text-simsek-green">Lesen →</span>
              </div>
            </a>
          ))}
        </div>
