    {
      '@type': 'Question',
      name: 'Welche Logopädie-Stellen sind in Duisburg ausgeschrieben?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Die Praxis für Logopädie Şimşek sucht Logopädinnen, Logopäden und Sprachtherapeutinnen (m/w/d) in Vollzeit oder Teilzeit am Standort Tonhallenstraße 21 in Duisburg.',
      },
    },
    {
      '@type': 'Question',
