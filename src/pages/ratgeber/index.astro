---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import Navigation from '../../components/Navigation.astro';
import Footer from '../../components/Footer.astro';

const beitraege = (await getCollection('ratgeber', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime()
);

const kategorieColors: Record<string, string> = {
  'Karriere':    'bg-simsek-green/10 text-simsek-green border-simsek-green/20',
  'Gehalt':      'bg-simsek-blue/10 text-simsek-blue border-simsek-blue/20',
  'Arbeitszeit': 'bg-amber-50 text-amber-700 border-amber-200',
  'Fachwissen':  'bg-violet-50 text-violet-700 border-violet-200',
};
const badgeClass = (kat: string) => kategorieColors[kat] ?? 'bg-slate-100 text-slate-600 border-slate-200';

const fmt = (d: Date) => d.toLocaleDateString('de-DE', { day: '2-digit', month: 'long', year: 'numeric' });
---

<Layout
  title="Ratgeber für Logopädinnen — Karriere, Gehalt, Fachwissen | Logopädiejobs.de"
  description="Artikel, Guides und Erfahrungsberichte rund um Logopädie, Sprachtherapie und den Arbeitsalltag in Praxis und Klinik. Fokus NRW und Ruhrgebiet."
  breadcrumbs={[
    { name: "Startseite", url: "https://xn--logopdiejobs-kcb.de/" },
    { name: "Ratgeber", url: "https://xn--logopdiejobs-kcb.de/ratgeber/" },
  ]}
>
  <Navigation />

  <main class="max-w-4xl mx-auto px-6 py-16 md:py-24">

    <!-- Header -->
    <header class="mb-12">
      <span class="inline-flex items-center px-3 py-1 rounded-full text-xs font-bold uppercase tracking-widest bg-simsek-green/10 text-simsek-green border border-simsek-green/20 mb-6">
        Ratgeber
      </span>
      <h1 class="text-4xl md:text-5xl font-bold text-slate-900 leading-tight mb-6">
        Ratgeber für Logopädinnen und Sprachtherapeuten
      </h1>
      <p class="text-xl text-slate-600 leading-relaxed max-w-2xl">
        Praxisnahe Artikel zu Gehalt, Arbeitszeit, Fachwissen und Karrierewegen in der Logopädie — mit Schwerpunkt auf NRW und dem Ruhrgebiet.
      </p>
      <div class="mt-8 h-px bg-linear-to-r from-simsek-green via-simsek-blue/40 to-transparent"></div>
    </header>

    <!-- Article list -->
    {beitraege.length === 0 ? (
      <div class="text-center py-16 text-slate-400">
        <p class="text-lg font-medium mb-2">Noch keine Artikel veröffentlicht.</p>
        <p class="text-sm">Der erste folgt in Kürze.</p>
      </div>
    ) : (
      <ul class="space-y-5 list-none p-0">
        {beitraege.map((b) => (
          <li>
            <div class="card-border group/card">
              <a
                href={`/ratgeber/${b.id}/`}
                class="block bg-white rounded-[14px] p-6 no-underline transition-all duration-200 hover:shadow-lg hover:shadow-simsek-green/20"
              >
                <div class="flex items-start justify-between gap-4 flex-wrap">
                  <div class="flex-1 min-w-0">
                    <span class={`inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-bold uppercase tracking-widest border mb-3 ${badgeClass(b.data.kategorie)}`}>
                      {b.data.kategorie}
                    </span>
                    <h2 class="text-xl font-bold text-slate-900 mb-2 leading-snug">
                      {b.data.title}
                    </h2>
                    <p class="text-slate-500 text-sm leading-relaxed mb-3 line-clamp-2">
                      {b.data.description}
                    </p>
                    <div class="flex items-center gap-2 text-xs text-slate-400">
                      <span class="font-medium">{b.data.author}</span>
                      <span>·</span>
                      <span>{fmt(b.data.pubDate)}</span>
                    </div>
                  </div>
                  <!-- Arrow icon -->
                  <div class="shrink-0 w-9 h-9 rounded-full bg-slate-100 group-hover/card:bg-linear-to-br group-hover/card:from-simsek-green group-hover/card:to-simsek-blue flex items-center justify-center transition-all duration-300">
                    <svg class="w-4 h-4 text-slate-400 group-hover/card:text-white transition-colors duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
                    </svg>
                  </div>
                </div>
              </a>
            </div>
          </li>
        ))}
      </ul>
    )}

  </main>

  <Footer />
</Layout>

<style>
  .card-border {
    position: relative;
    border-radius: 1rem;
    isolation: isolate;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }

  .card-border::before {
    content: '';
    position: absolute;
    inset: -2px;
    border-radius: calc(1rem + 2px);
    background: linear-gradient(135deg, rgb(129 183 40), rgb(36 135 193));
    z-index: -1;
  }

  .card-border:hover {
    transform: scale(1.01);
  }
</style>
