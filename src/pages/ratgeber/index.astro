---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import Navigation from '../../components/Navigation.astro';
import Footer from '../../components/Footer.astro';

const beitraege = (await getCollection('ratgeber', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime()
);
---

<Layout
  title="Ratgeber für Logopädinnen — Karriere, Gehalt, Fachwissen | Logopädiejobs.de"
  description="Artikel, Guides und Erfahrungsberichte rund um Logopädie, Sprachtherapie und den Arbeitsalltag in Praxis und Klinik. Fokus NRW und Ruhrgebiet."
  breadcrumbs={[
    { name: "Startseite", url: "https://xn--logopdiejobs-kcb.de/" },
    { name: "Ratgeber", url: "https://xn--logopdiejobs-kcb.de/ratgeber/" },
  ]}
>
  <Navigation />
  <main>
    <article class="max-w-4xl mx-auto px-6 py-16 md:py-24">
      <header class="mb-12">
        <p class="text-sm font-bold uppercase tracking-widest text-simsek-green mb-4">Ratgeber</p>
        <h1 class="text-4xl md:text-5xl font-bold text-slate-900 leading-tight mb-6">
          Ratgeber für Logopädinnen und Sprachtherapeuten
        </h1>
        <p class="text-xl text-slate-600 leading-relaxed">
          Praxisnahe Artikel zu Gehalt, Arbeitszeit, Fachwissen und Karrierewegen in der Logopädie — mit Schwerpunkt auf NRW und dem Ruhrgebiet.
        </p>
      </header>

      {beitraege.length === 0 ? (
        <p class="text-slate-500">Noch keine Artikel veröffentlicht. Der erste folgt in Kürze.</p>
      ) : (
        <ul class="grid gap-6 list-none p-0">
          {beitraege.map((b) => (
            <li>
              <a href={`/ratgeber/${b.id}/`} class="block p-6 rounded-2xl border border-slate-200 hover:border-simsek-blue transition-colors no-underline">
                <p class="text-xs font-bold uppercase tracking-widest text-simsek-green mb-2">{b.data.kategorie}</p>
                <h2 class="text-xl md:text-2xl font-bold text-slate-900 mb-2">{b.data.title}</h2>
                <p class="text-slate-600 mb-3">{b.data.description}</p>
                <p class="text-xs text-slate-400">
                  {b.data.author} · {b.data.pubDate.toLocaleDateString('de-DE', { day: '2-digit', month: 'long', year: 'numeric' })}
                </p>
              </a>
            </li>
          ))}
        </ul>
      )}
    </article>
  </main>
  <Footer />
</Layout>
