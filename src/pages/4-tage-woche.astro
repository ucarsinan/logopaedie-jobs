---
import Layout from '../layouts/Layout.astro';

const destination = '/ratgeber/4-tage-woche-logopaedie/';
---

<Layout
  title="4-Tage-Woche Logopädie | Weiterleitung"
  description="Weiterleitung zum Ratgeber über die 4-Tage-Woche in der Logopädie."
  canonicalUrl={destination}
  robots="noindex, follow"
>
  <meta slot="head" http-equiv="refresh" content={`0; url=${destination}`} />
  <script slot="head" is:inline define:vars={{ destination }}>
    window.location.replace(destination);
  </script>
  <main class="min-h-screen flex items-center justify-center px-6">
    <a href={destination} class="text-simsek-blue font-bold underline underline-offset-4">Zum Artikel 4-Tage-Woche Logopädie</a>
  </main>
</Layout>
