---
import Layout from '../layouts/Layout.astro';
import Navigation from '../components/Navigation.astro';
import Footer from '../components/Footer.astro';
---

<Layout
  title="Impressum | Praxis für Logopädie Şimşek"
  description="Impressum der Praxis für Logopädie Şimşek, Tonhallenstraße 21, 47051 Duisburg"
  breadcrumbs={[
    { name: "Logopädie Jobs Duisburg", url: "https://xn--logopdiejobs-kcb.de/" },
    { name: "Impressum", url: "https://xn--logopdiejobs-kcb.de/impressum" }
  ]}
>
  <Navigation />
  <main>
    <article class="max-w-3xl mx-auto px-6 py-16 md:py-24">

      <!-- Breadcrumb -->
      <nav class="flex items-center gap-2 text-xs text-slate-400 mb-10 font-medium flex-wrap" aria-label="Breadcrumb">
        <a href="/" class="hover:text-simsek-green transition-colors duration-150 no-underline">Startseite</a>
        <svg class="w-3 h-3 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
        <span class="text-slate-600">Impressum</span>
      </nav>

      <header class="mb-12">
        <span class="inline-flex items-center px-3 py-1 rounded-full text-xs font-bold uppercase tracking-widest bg-slate-100 text-slate-600 border border-slate-200 mb-6">
          Rechtliches
        </span>
        <h1 class="text-4xl md:text-5xl font-bold text-slate-900 leading-tight mb-6">
          Impressum
        </h1>
        <div class="h-px bg-linear-to-r from-simsek-green via-simsek-blue/40 to-transparent"></div>
      </header>

      <div class="article-body">
        <h2>Angaben gemäß § 5 TMG</h2>
        <p>
          Praxis für Logopädie Şimşek<br/>
          Tonhallenstraße 21<br/>
          47051 Duisburg
        </p>

        <h2>Kontakt</h2>
        <p>
          Telefon: +49 (0) 203 3486 8690<br/>
          E-Mail: <a href="mailto:info@logopaedie-simsek.de">info@logopaedie-simsek.de</a>
        </p>

        <h2>Verantwortlich für den Inhalt nach § 55 Abs. 2 RStV</h2>
        <p>
          Emel Şimşek-Uçar<br/>
          Tonhallenstraße 21<br/>
          47051 Duisburg
        </p>

        <h2>Haftungsausschluss</h2>
        <p>Die Inhalte dieser Website wurden mit größtmöglicher Sorgfalt erstellt. Für die Richtigkeit, Vollständigkeit und Aktualität der Inhalte können wir jedoch keine Gewähr übernehmen.</p>
      </div>

    </article>
  </main>
  <Footer />
</Layout>

<style>
  :global(.article-body) {
    font-size: 1.0625rem;
    line-height: 1.8;
    color: #334155;
  }

  :global(.article-body p) {
    margin-bottom: 1.5rem;
  }

  :global(.article-body h2) {
    font-size: 1.25rem;
    font-weight: 700;
    color: #0f172a;
    margin-top: 2.5rem;
    margin-bottom: 1rem;
    padding-left: 1rem;
    border-left: 3px solid rgb(129 183 40);
    line-height: 1.3;
  }

  :global(.article-body a) {
    color: rgb(36 135 193);
    text-decoration: underline;
    text-underline-offset: 3px;
    font-weight: 500;
    transition: color 0.15s;
  }

  :global(.article-body a:hover) {
    color: rgb(129 183 40);
  }

  :global(.article-body strong) {
    font-weight: 600;
    color: #0f172a;
  }
</style>
