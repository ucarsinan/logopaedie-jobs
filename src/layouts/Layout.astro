---
import '../styles/global.css'; // Lädt Tailwind v4 inklusive deiner simsek-Farben
import JobSchema from '../components/JobSchema.astro';
import FaqSchema from '../components/FaqSchema.astro';

interface BreadcrumbItem {
    name: string;
    url: string;
}

interface Props {
    title: string;
    description: string;
    ogImage?: string;
    breadcrumbs?: BreadcrumbItem[];
}

const { title, description, ogImage, breadcrumbs } = Astro.props;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
---

<!doctype html>
<html lang="de" class="scroll-smooth">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1" />

        <title>{title}</title>
        <meta name="description" content={description} />
        <link rel="canonical" href={canonicalURL} />
        <link rel="alternate" hreflang="de" href={canonicalURL} />
        <link rel="alternate" hreflang="x-default" href={canonicalURL} />

        <meta property="og:type" content="website" />
        <meta property="og:locale" content="de_DE" />
        <meta property="og:url" content={canonicalURL} />
        <meta property="og:title" content={title} />
        <meta property="og:description" content={description} />
        <meta property="og:image" content={ogImage ? new URL(ogImage, Astro.site) : new URL('/og-image.png', Astro.site)} />

        <meta property="twitter:card" content="summary_large_image" />
        <meta property="twitter:url" content={canonicalURL} />
        <meta property="twitter:title" content={title} />
        <meta property="twitter:description" content={description} />
        <meta property="twitter:image" content={ogImage ? new URL(ogImage, Astro.site) : new URL('/og-image.png', Astro.site)} />

        <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

        <meta name="robots" content="index, follow, max-snippet:-1, max-image-preview:large, max-video-preview:-1" />
        <JobSchema />
        <FaqSchema />
        <slot name="head" />
        {breadcrumbs && breadcrumbs.length > 0 && (
          <script type="application/ld+json" is:inline set:html={JSON.stringify({
            "@context": "https://schema.org",
            "@type": "BreadcrumbList",
            "itemListElement": breadcrumbs.map((item, index) => ({
              "@type": "ListItem",
              "position": index + 1,
              "name": item.name,
              "item": item.url
            }))
          })} />
        )}
    </head>
    <body class="bg-white text-slate-900 selection:bg-simsek-green/20 selection:text-simsek-blue antialiased">
        <slot />
    </body>
</html>