---
import '../styles/global.css'; // Lädt Tailwind v4 inklusive deiner simsek-Farben

interface BreadcrumbItem {
    name: string;
    url: string;
}

interface Props {
    title: string;
    description: string;
    canonicalUrl?: string;
    ogImage?: string;
    breadcrumbs?: BreadcrumbItem[];
    robots?: string;
}

const { title, description, canonicalUrl, ogImage, breadcrumbs, robots } = Astro.props;
const canonicalURL = canonicalUrl ? new URL(canonicalUrl, Astro.site) : new URL(Astro.url.pathname, Astro.site);
const isLegalPage = ['/impressum', '/datenschutz'].some(p => Astro.url.pathname.startsWith(p));
const gaMeasurementId = import.meta.env.PUBLIC_GA_MEASUREMENT_ID;
---

<!doctype html>
<html lang="de" class="scroll-smooth">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1" />

        <title>{title}</title>
        <meta name="description" content={description} />
        <link rel="canonical" href={canonicalURL} />
        <link rel="alternate" hreflang="de" href={canonicalURL} />
        <link rel="alternate" hreflang="x-default" href={canonicalURL} />

        <meta property="og:type" content="website" />
        <meta property="og:locale" content="de_DE" />
        <meta property="og:url" content={canonicalURL} />
        <meta property="og:title" content={title} />
        <meta property="og:description" content={description} />
        <meta property="og:image" content={ogImage ? new URL(ogImage, Astro.site) : new URL('/og-image.png', Astro.site)} />

        <meta property="twitter:card" content="summary_large_image" />
        <meta property="twitter:url" content={canonicalURL} />
        <meta property="twitter:title" content={title} />
        <meta property="twitter:description" content={description} />
        <meta property="twitter:image" content={ogImage ? new URL(ogImage, Astro.site) : new URL('/og-image.png', Astro.site)} />

        <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

        <meta name="robots" content={robots ?? (isLegalPage ? 'noindex, nofollow' : 'index, follow, max-snippet:-1, max-image-preview:large, max-video-preview:-1')} />
        <slot name="head" />
        {breadcrumbs && breadcrumbs.length > 0 && (
          <script type="application/ld+json" is:inline set:html={JSON.stringify({
            "@context": "https://schema.org",
            "@type": "BreadcrumbList",
            "itemListElement": breadcrumbs.map((item, index) => ({
              "@type": "ListItem",
              "position": index + 1,
              "name": item.name,
              "item": item.url
            }))
          })} />
        )}
        {gaMeasurementId && (
          <script is:inline define:vars={{ gaMeasurementId }}>
            (function () {
              window.dataLayer = window.dataLayer || [];
              window.gtag = window.gtag || function(){ window.dataLayer.push(arguments); };

              function loadAnalytics() {
                if (window.__jobsGaLoaded || !gaMeasurementId) return;
                var script = document.createElement('script');
                script.async = true;
                script.src = 'https://www.googletagmanager.com/gtag/js?id=' + encodeURIComponent(gaMeasurementId);
                document.head.appendChild(script);
                window.__jobsGaLoaded = true;
                window.gtag('js', new Date());
              }

              function trackPageview() {
                window.gtag('config', gaMeasurementId, {
                  page_path: location.pathname + location.search,
                  page_title: document.title,
                  anonymize_ip: true,
                  storage: 'none',
                  client_storage: 'none'
                });
              }

              loadAnalytics();
              document.addEventListener('DOMContentLoaded', trackPageview);
            })();
          </script>
        )}
    </head>
    <body class="bg-white text-slate-900 selection:bg-simsek-green/20 selection:text-simsek-blue antialiased">
        <slot />
    </body>
</html>
