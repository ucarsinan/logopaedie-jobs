      "destination": "/ratgeber/gehalt-logopaedie-nrw/",
      "permanent": true
    },
    {
      "source": "/gehalt/",
      "destination": "/ratgeber/gehalt-logopaedie-nrw/",
      "permanent": true
    },
    {
      "source": "/4-tage-woche",
      "destination": "/ratgeber/4-tage-woche-logopaedie/",
      "permanent": true
    },
    {
      "source": "/4-tage-woche/",
      "destination": "/ratgeber/4-tage-woche-logopaedie/",
      "permanent": true
    },
    {
      "source": "/bilingual",
      "destination": "/ratgeber/bilinguale-sprachtherapie/",
      "permanent": true
    },
    {
      "source": "/bilingual/",
      "destination": "/ratgeber/bilinguale-sprachtherapie/",
      "permanent": true
    }
